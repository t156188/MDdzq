{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDGEM",
  "version": "0.1.0",
  "identifier": "com.lv.mdreader",
  "build": {
    "frontendDist": "../../mac/Resources"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "Copyright © 2026",
    "shortDescription": "Lightweight Markdown reader",
    "longDescription": "Read Markdown files with code highlighting, Mermaid diagrams and KaTeX formulas.",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "targets": ["nsis", "dmg"],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mkdn"],
        "name": "Markdown Document",
        "description": "Markdown source file",
        "role": "Viewer",
        "mimeType": "text/markdown"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
